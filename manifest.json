{
  "manifest_version": 2,
  "name": "VPN Privacy Guard",
  "description": "Controls connections to certain domains (including subdomains) depending on your VPN's state",
  "version": "1.0",
  "icons": {
    "48": "icons/block.svg",
    "96": "icons/block.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "strict_min_version": "91.0",
      "id": "vpn-privacy-guard@examle.com"
    }
  },
  "background": {
    "scripts": [
      "proxy-handler.js"
    ]
  },
  "options_ui": {
    "page": "options/options.html",
    "browser_style": true
  },
  "permissions": ["storage", "history", "tabs", "webNavigation", "webRequest", "webRequestBlocking", "<all_urls>"]
}