{
    "manifest_version": 2,
    "name": "VPN Privacy Guard",
    "description": "Blocks connections to certain domains (with subdomains) when your VPN is down",
    "version": "3.0",
    "icons": {
        "48": "icons/block.svg",
        "96": "icons/block.svg"
    },
    "browser_specific_settings": {
        "gecko": {
            "strict_min_version": "91",
            "id": "vpn-privacy-guard@examle.com"
        }
    },
    "background": {
        "scripts": [
            "proxy-handler.js"
        ]
    },
    "options_ui": {
        "page": "options/options.html",
        "browser_style": true
    },
    "permissions": [
        "proxy",
        "storage",
        "history",
        "tabs",
        "webNavigation",
        "<all_urls>"
    ]
}